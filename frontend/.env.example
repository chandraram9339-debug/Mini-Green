# --- Локальная разработка (pnpm dev:miniapp) ---
# Рекомендуется: пустой `VITE_API_BASE_URL` — фронт ходит на тот же хост/порт, что Vite, а Vite проксирует API
# на `VITE_DEV_API_TARGET` (меняете только порт бэка в одном месте, если не 4000).
VITE_API_BASE_URL=
VITE_DEV_API_TARGET=http://127.0.0.1:4000
# Полный mock без бэка в dev: VITE_DEV_USE_VITE_PROXY=false
# VITE_DEV_USE_VITE_PROXY=false

# Альтернатива без прокси: явный URL (тогда `VITE_DEV_API_TARGET` для Vite не используется)
# VITE_API_BASE_URL=http://127.0.0.1:4000

# Санитизированный снимок AL trade-feed (Bearer → бэкенд читает последний JSON из БД; Basic Auth только на сервере).
# По умолчанию путь совпадает с GET /trading/al-trade-feed в miniappRoutes.
# VITE_API_TRADE_FEED_PATH=/trading/al-trade-feed

# Интервал опроса снимка на экране бота (мс). По умолчанию 5000, мин 3000, макс 30000.
# VITE_AL_TRADE_FEED_POLL_MS=5000

# Санитизированный снимок AL /api/state (Bearer → бэкенд; секреты только в env бэкенда).
# VITE_API_AL_STATE_PATH=/trading/al-state
# VITE_AL_STATE_POLL_MS=5000

# Экран бота: как часто обновлять журнал и статистику с API (мс, мин. 2000). По умолчанию 5000.
# VITE_BOT_DETAIL_REFRESH_MS=5000

# Legacy external links (optional)
VITE_CHANNEL_URL=https://example.com/channel
VITE_CHAT_URL=https://example.com/chat
VITE_YOUTUBE_URL=https://example.com/youtube
VITE_SUPPORT_URL=https://example.com/support
VITE_REFERRAL_URL=https://example.com/referral
# Текст при шаринге реферальной ссылки (t.me/share/url). По умолчанию в коде: «💰 Palladium trade bot!»
# VITE_REFERRAL_SHARE_MESSAGE=💰 Palladium trade bot!

# TON Connect (манифест должен быть доступен по HTTPS в проде).
# Пусто → используется `${window.location.origin}/tonconnect-manifest.json`.
# VITE_TONCONNECT_MANIFEST_URL=https://your-miniapp-host/tonconnect-manifest.json
#
# Только для dev вне Telegram: числовой Telegram id для memo в TON-транзакции.
# VITE_DEV_TON_DEPOSIT_COMMENT=123456789
