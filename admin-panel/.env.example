# Optional: API origin when the admin UI is served from a different host than the backend.
# Example: admin at https://admin.example.com, API at https://api.example.com
# VITE_API_BASE=https://api.example.com

# Optional: URL path prefix when nginx serves this app under a subpath (not on subdomain root).
# Build with: VITE_ADMIN_BASE=/admin-ui/ pnpm build
# Dev default is "/" (http://127.0.0.1:5180/)
# VITE_ADMIN_BASE=/admin-ui/
