# NOTE:
# This file mirrors `.env` for local bootstrap only.
# QA/war-room reruns must use `/home/ramos/Документы/miniapp/backend/.env` as runtime source.
PORT=4000
DATABASE_URL=postgresql://miniapp:miniapp@localhost:5432/miniapp
REDIS_URL=redis://localhost:6379
DB_RUNTIME_PROFILE_ID=db-runtime-v1
EXECUTION_MODE=mock
AUTH_PROVIDER_MODE=mock
DEMO_INIT_USER_ID=10001
DEMO_INIT_TOKENS=demo-smoke-init,demo-smoke-init-2
MOCK_INITDATA_SECRET=mock-init-secret-v1
MOCK_INITDATA_MAX_AGE_SEC=86400
# For provider-like QA verification set:
# AUTH_PROVIDER_MODE=telegram
# TELEGRAM_BOT_TOKEN=<real bot token from secret manager>
# ENABLE_OPS_LOGS=true
TELEGRAM_BOT_TOKEN=replace-me
ACTION_STORE_PATH=./runtime/action-store.json
ENABLE_OPS_LOGS=true
