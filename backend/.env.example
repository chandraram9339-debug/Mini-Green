# Copy to `.env` for local runs. Do not commit real secrets.
#
# ——— SQLite: все пользователи, зашифрованные сиды (WALLET_SEED_PER_USER), депозитные адреса,
# балансы, депозиты/выводы — лежат в ОДНОМ файле БД. Укажите абсолютный путь на проде и смонтируйте том.
# TronGrid (TRON_API_KEY) — только ключ к RPC; он НЕ подставляется «на каждого пользователя» и хранится в env.
# Приватные ключи депозита НЕ дублируем в открытом виде в БД: при пер-пользовательской мнемонике ключ восстанавливается из ciphertext.
# Резервная копия: scripts/backup-sqlite.sh (копирует .db и -wal/-shm).
DB_PATH=
# FULL — максимально безопасная запись на диск (рекомендуется для прод с кошельками). Локально можно NORMAL.
SQLITE_SYNC=FULL

# ——— Telegram + TronGrid (подвязка) ———
# 1) Токен бота: @BotFather → API token → TELEGRAM_BOT_TOKEN
# 2) TronGrid: https://www.trongrid.io/ (или dashboard) → Create API Key → TRON_API_KEY
# 3) Mainnet: TRON_FULL_HOST=https://api.trongrid.io  (Nile testnet: https://nile.trongrid.io)
# 4) Проверка без утечки секретов: GET /admin/integrations/verify  +  X-Admin-Key: <ADMIN_API_KEY>
# 5) Мини-ап в прод: AUTH_PROVIDER_MODE=telegram, реальный initData
# 6) Вебхук (Subscribe, block): setWebhook на https://<хост>/hooks/telegram
#    Секрет — либо ?secret=<TELEGRAM_WEBHOOK_SECRET> в URL, либо secret_token= в setWebhook
#    (тогда приходит X-Telegram-Bot-Api-Secret-Token, без query).

PORT=4000
EXECUTION_MODE=mock
AUTH_PROVIDER_MODE=mock
# mock: `DEMO_INIT_TOKENS` are accepted as raw `initData` string; or use signed initData (MOCK_INITDATA_SECRET)
DEMO_INIT_USER_ID=10001
DEMO_INIT_TOKENS=demo-smoke-init,demo-smoke-init-2
MOCK_INITDATA_SECRET=mock-init-secret-v1
MOCK_INITDATA_MAX_AGE_SEC=86400
# For real Telegram WebApp initData verification:
# AUTH_PROVIDER_MODE=telegram
# TELEGRAM_BOT_TOKEN=

TELEGRAM_BOT_TOKEN=
ACTION_STORE_PATH=./runtime/action-store.json
ENABLE_OPS_LOGS=true
# Лог в stdout каждой строки SIB при sync AL (сотни строк). По умолчанию только сводка `sib.adjust.summary`.
# LOG_EACH_SIB_ADJUST=1

# JWT (see ../figma-miniapp-frontend/INTEGRATION.md)
JWT_SECRET=dev-only-insecure-jwt-do-not-use-in-prod
JWT_ACCESS_TTL_SEC=604800

# CORS: comma/semicolon/space-separated browser origins. Empty = allow all (dev).
# Production (Telegram WebApp): set your miniapp HTTPS origin and typically https://web.telegram.org
# CORS_ORIGINS=https://your-miniapp.example,https://web.telegram.org
CORS_ORIGINS=

# Fallback TRC20 treasury (if per-user HD/deterministic address is not configured)
# DEPOSIT_ADDRESS=
# TREASURY_USDT_TRC20=

# USDT in minor units (1 USDT = 100). Fees: fixed USDT + bps (100 bps = 1%). min_withdraw_usdt also in app_config.
MIN_DEPOSIT_USDT=7
DEPOSIT_FEE_FIXED_USDT=7
DEPOSIT_FEE_BPS=900
MIN_WITHDRAW_MINOR=700
WITHDRAW_FEE_FIXED_USDT=7
WITHDRAW_FEE_BPS=1900
REFERRAL_PERCENT_BPS=800
# "all" or e.g. "1,2,3" (which deposit # pays referral)
REFERRAL_DEPOSIT_COUNTS=all

# Per-user TRON address derivation (one of: mnemonic, deterministic HMAC, or mock/execution mock)
# HD_WALLET_MNEMONIC=twelve words ...
# Hex HMAC key, 32+ bytes when mnemonic is empty
DETERMINISTIC_DERIVE_KEY=

# On-chain: TronGrid + USDT TRC20; LIVE_TRON=0 uses stub amount on PAID
# When TRON_API_KEY is set, set LIVE_TRON=1 to credit deposits from real on-chain USDT (see GET /admin/integrations/verify → wallets).
LIVE_TRON=0
# Real broadcasts (deposits: GAZ TRX + USDT sweep to topup; withdraws: USDT from float). Needs keys + valid Tron base58 in app_config / env.
LIVE_TRON_SEND=0
# Hex 64, no 0x — GAZ hot wallet, sends GAS_TRX_TO_USER_SUN TRX to the user’s deposit address first
GAZ_BANK_PRIVATE_KEY=
# Hex 64 — hot wallet with USDT float, pays user on withdrawal when LIVE_TRON_SEND=1
WITHDRAW_WALLET_PRIVATE_KEY=
# TRX in sun (1 TRX = 1_000_000)
GAS_TRX_TO_USER_SUN=2000000
TRON_FEE_LIMIT_SUN=80000000
TRON_FULL_HOST=https://api.trongrid.io
TRON_API_KEY=
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
STUB_DEPOSIT_GROSS_USDT=100

# Уникальная BIP39 на пользователя (хранится зашифрованной в users.wallet_mnemonic_encrypted), адрес TRON m/44'/195'/0'/0/0.
# При WALLET_SEED_PER_USER=1 задайте USER_WALLET_ENCRYPTION_KEY — ровно 64 hex-символа (32 байта AES-256-GCM).
WALLET_SEED_PER_USER=0
# Депозитный кошелёк: приватный ключ в users.deposit_private_key_encrypted (AES-GCM тем же USER_WALLET_ENCRYPTION_KEY).
# Имеет приоритет над WALLET_SEED_PER_USER. Генерация: локально (tronweb) или POST на URL ниже (ответ JSON: address, privateKey).
# Официальный TronGrid НЕ создаёт кошельки — это ваш микросервис или локальная генерация (URL пустой).
WALLET_STORE_ENCRYPTED_PK=0
# POST JSON { "tg_user_id": "<telegram id>" } → JSON { "address", "privateKey" } (64 hex).
# Local dev mock: pnpm run mock:wallet-create  →  http://127.0.0.1:4711
TRON_DEPOSIT_WALLET_CREATE_URL=
TRON_DEPOSIT_WALLET_CREATE_AUTH=
TRON_DEPOSIT_WALLET_CREATE_TIMEOUT_MS=15000
# Generate: pnpm --dir backend gen:wallet-key
USER_WALLET_ENCRYPTION_KEY=

# App account recovery (mini-app identity). Random long secret; empty = recovery UI disabled.
# Generate (from backend/): pnpm gen:recovery-pepper
# RECOVERY_CODE_PEPPER=

# Admin API: header X-Admin-Key. Also: GET/PATCH /admin/config, /admin/meta-accounts, /admin/stats (v2)
ADMIN_API_KEY=
# Auto-approve withdraw without manual admin step (used when DB key withdraw_auto_approve is unset)
WITHDRAW_AUTO_APPROVE=0
# Bot username without @ — fallback referral link https://t.me/<name>?start=ref_<tg>; admin «Контент» overrides
PUBLIC_TELEGRAM_BOT_USERNAME=

# Meta Conversions API (optional). «Subscribe» (старт бота) + «Purchase» (депозит) — те же пиксели; /start и webhook (см. TELEGRAM_WEBHOOK_SECRET).
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# Log labels for on-chain send ops (not hot wallet keys)
GAZ_BANK_ADDRESS=GAZ_BANK
TOPUP_BANK_ADDRESS=TOP_UP_BANK
WITHDRAW_WALLET_ADDRESS=WITHDRAW_WALLET

# Telegram: `POST /hooks/telegram?secret=...` (set webhook URL in @BotFather) for my_chat_member (block/unblock) + message activity
TELEGRAM_WEBHOOK_SECRET=

# pnpm: native module `better-sqlite3` must build on install. If startup fails
# with "Could not locate the bindings file", run: `cd node_modules/better-sqlite3 && npm run install`
# (or reinstall after `package.json` includes pnpm.onlyBuiltDependencies / `pnpm approve-builds`).

# ——— External trading engine (optional) ———
# Outbound: when the user taps Start/Stop in the miniapp, POST JSON `{ tg_user_id, action }` to this URL if set.
# TRADING_ENGINE_NOTIFY_URL=https://your-engine-host/internal/trading-hook
# TRADING_ENGINE_NOTIFY_TIMEOUT_MS=8000
#
# Inbound: positions/state sync from the engine → POST /hooks/trading/v1/ingest with header X-Trading-Secret
# TRADING_INGEST_SECRET=
#
# SIB: optional POST `{ "tg_user_id" }` after deposit / withdraw sent so the engine can push journal + closes
# SIB_JOURNAL_SYNC_URL=
#
# ——— AL trading simulator (pull) ———
# Polls the external host GET /api/trade-feed with HTTP Basic; mirrors opens/closes + SIB for listed Telegram IDs.
# The same base URL + Basic auth are also used for GET /api/state (cached ~3s): live price in miniapp
# `/trading/summary` and sanitized GET `/trading/al-state` (Bearer JWT; no Basic on the client).
# AL must use the same Basic creds (AL’s ADMIN_USER / ADMIN_PASSWORD) as AL_TRADE_FEED_HTTP_USER / AL_TRADE_FEED_HTTP_PASSWORD.
# AL_TRADE_FEED_ENABLED=0
# AL_TRADE_FEED_BASE_URL=https://trading-algoritm.site
# AL_TRADE_FEED_HTTP_USER=
# AL_TRADE_FEED_HTTP_PASSWORD=
# Секунд паузы после **завершения** каждого sync (следующий pull AL), не чаще ~1/3 c. По умолчанию 8.
# AL_TRADE_FEED_POLL_INTERVAL_SEC=8
# Comma-separated numeric Telegram user ids (same feed applied to each)
# AL_TRADE_FEED_SYNC_TG_IDS=
# USDT minor for position size in our DB (AL entry price is not stored)
# AL_POSITION_NOTIONAL_MINOR=100000
#
# После каждого успешного pull полный JSON GET /api/trade-feed пишется в al_trade_feed_snapshots — иначе GET /trading/al-trade-feed пустой.
# Флаг AL_TRADE_FEED_STORE_SNAPSHOTS=1 включает pruning (retention/max rows); при 0 снимки всё равно пишутся, но старые строки не удаляются по расписанию.
# AL_TRADE_FEED_STORE_SNAPSHOTS=1
# AL_TRADE_FEED_SNAPSHOT_RETENTION_DAYS=7
# AL_TRADE_FEED_SNAPSHOT_MAX_ROWS=2000

# ——— TON: центральный кошелёк + TonAPI (опционально) ———
# Адрес из админки пишется в app_config `central_ton_deposit_address` и перекрывает env.
# CENTRAL_TON_DEPOSIT_ADDRESS=
# TONAPI_BASE_URL=https://tonapi.io
# TONAPI_KEY=
# USDT jetton master (mainnet Tether по умолчанию в коде)
# TON_USDT_JETTON_MASTER=EQCxE6mUtQJKFnGfa8Z6f18GHuCeI6vtBed1GDHnHHT
# Пуллинг входящих на центральный адрес (stub bridge → зачисление USDT в ledger, см. tonDepositIngest)
# TON_INGEST_ENABLED=0
# TON_INGEST_POLL_SEC=45
# Гросс в minor (10000 = 100 USDT) — пока bridge заглушка
# TON_INGEST_STUB_GROSS_MINOR=10000
